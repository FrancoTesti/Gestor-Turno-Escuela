    public class Usuario
    {
        public int IdUsuario { get; set; }
        public string NombreUsuario { get; set; } // ej: "jperez"
        public string Contrasena { get; set; } // En la vida real esto va encriptado (hash)
        public bool EstaActivo { get; set; } // Para dar de baja a alguien sin borrar sus registros

        public Usuario(int id, string nombreUsuario, string contrasena, bool activo = true)
        {
            IdUsuario = id;
            NombreUsuario = nombreUsuario;
            Contrasena = contrasena;
            EstaActivo = activo;
        }

        // Método de ejemplo para verificar login
        public bool ValidarCredenciales(string usuario, string pass)
        {
            return NombreUsuario == usuario && Contrasena == pass && EstaActivo;
        }
    }
        public class Alumno
        {
            public int IdAlumno { get; private set; }
            public string Nombre { get; private set; }
            public string Apellido { get; private set; }
            public string Grado { get; private set; }
            public string Curso { get; private set; }
            public string Estado { get; private set; }

            public void SetEstado(string nuevoEstado)
            {
                if (string.IsNullOrWhiteSpace(nuevoEstado))
                    throw new System.ArgumentException("El estado no puede estar vacío.", nameof(nuevoEstado));

                Estado = nuevoEstado;
            }

            public Alumno(int id, string nombre, string apellido, string grado, string curso)
            {
                IdAlumno = id;
                Nombre = nombre;
                Apellido = apellido;
                Grado = grado;
                Curso = curso;
                Estado = null;
            }
        }

