        public class ValidadorRetiro
        {
            // simulamos una base de datos temporal con listas
            // en el futuro, esto consultará una base de datos real
            public bool ValidarPermiso(int idAlumno, int idTutor, List<Autorizacion> autorizaciones)
            {
                // buscamos si existe la relación en la lista de autorizaciones
                foreach (var aut in autorizaciones)
                {
                    if (aut.AlumnoId == idAlumno && aut.TutorId == idTutor)
                    {
                        return true; // autorizado
                    }
                }

                return false; // no autorizado
            }

            public Retiro RegistrarEvento(int idAlu, int idTut, int idPers, string obs = "")
            {
                return new Retiro(0, idAlu, idTut, idPers, DateTime.Now, obs);
            }
        }
